{
  "oxc.enable": true,
  "eslint.enable": false,
  "prettier.enable": false,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "js/ts.experimental.useTsgo": true,
  "cSpell.words": [
    "browserslistrc",
    "bumpp",
    "changelogithub",
    "csso",
    "esbuild",
    "icss",
    "iife",
    "importee",
    "jridgewell",
    "jsxdev",
    "kwai",
    "lfcr",
    "nerv",
    "nextjs",
    "nocheck",
    "nosources",
    "ohpm",
    "oxfmt",
    "oxlint",
    "pnpm",
    "pxtransform",
    "systemjs",
    "tarojs",
    "taze",
    "tsdown",
    "tsgo",
    "unrs",
    "weapp"
  ],
  "cSpell.allowCompoundWords": true
}
